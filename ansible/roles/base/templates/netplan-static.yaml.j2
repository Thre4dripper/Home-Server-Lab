# This file is managed by Ansible — do not edit manually.
# cloud-init network management is disabled via /etc/cloud/cloud.cfg.d/99-disable-network-config.cfg
#
# Static IP eliminates the DHCP race condition that occurs when Pi reboots
# after a power cut: Pi boots faster than the router's DHCP server, leaving
# the interface IP-less. K3s then starts without a valid node IP, flannel
# sets up broken iptables rules that drop ALL incoming traffic (including SSH),
# and the state never self-heals until a manual reboot.
#
# With static IP, the address is assigned instantly — no router dependency.
# SSH becomes reachable immediately on boot. K3s waits for gateway reachability
# (ExecStartPre ping in 10-network-wait.conf) so it only starts once the router
# is actually up, even after a simultaneous power-cut reboot of both devices.
#
# Each host defines its primary interface and IP in host_vars/<hostname>.yml:
#   k3s_flannel_iface: "wlan0"         # or "eth0" (default)
#   netplan_static_ip: "192.168.0.108"
#   netplan_prefix_length: "24"
#   pi_gateway: "192.168.0.1"          # (or set in group_vars/all.yml)
#   netplan_wifi_ssid: "MyNetwork"     # only needed when k3s_flannel_iface=wlan0
#   netplan_wifi_password: "..."       # store in ansible/group_vars/vault.yml
network:
  version: 2
  ethernets:
    eth0:
      dhcp4: false
      dhcp6: false
      accept-ra: false
{% if k3s_flannel_iface | default('eth0') == 'eth0' %}
      addresses:
        - {{ netplan_static_ip }}/{{ netplan_prefix_length }}
      routes:
        - to: default
          via: {{ pi_gateway }}
      nameservers:
        addresses: {{ pi_dns_servers | to_json }}
{% else %}
      # eth0 not the primary interface — mark optional so it doesn't block
      # network-online.target when no cable is plugged in.
      optional: true
{% endif %}
{% if k3s_flannel_iface | default('eth0') == 'wlan0' %}
  wifis:
    wlan0:
      dhcp4: false
      dhcp6: false
      # optional: wlan0 won't block network-online.target; the k3s drop-in
      # ExecStartPre loop waits for gateway reachability instead.
      optional: true
      addresses:
        - {{ netplan_static_ip }}/{{ netplan_prefix_length }}
      routes:
        - to: default
          via: {{ pi_gateway }}
      nameservers:
        addresses: {{ pi_dns_servers | to_json }}
      access-points:
        {{ netplan_wifi_ssid | to_json }}:
          auth:
            key-management: "psk"
            password: {{ netplan_wifi_password | to_json }}
{% endif %}
