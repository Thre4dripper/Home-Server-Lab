# This file is managed by Ansible — do not edit manually.
# k3s server configuration
write-kubeconfig-mode: "0644"
disable:
  - traefik

# flannel-iface tells flannel which INTERFACE to use, not which IP.
# This avoids hardcoding an address and works correctly with both DHCP
# and static IP, and scales cleanly to multi-node setups where each
# node has its own IP on eth0.
flannel-iface: "eth0"

# K3s uses its own resolv.conf for CoreDNS upstream resolution.
# The main /etc/resolv.conf (managed by systemd-resolved) is separate.
resolv-conf: /etc/resolv.conf.k3s

tls-san:
  - "{{ ansible_default_ipv4.address }}"
  - "{{ ansible_hostname }}"
  - "{{ ansible_hostname }}.lan"

kubelet-arg:
  - "kube-reserved=cpu=100m,memory=256Mi"
  - "system-reserved=cpu=100m,memory=256Mi"
  - "eviction-hard=memory.available<200Mi"

# etcd tuning for SD card — slow fsync tolerance.
# Default heartbeat=100ms, election=1000ms are tuned for NVMe.
# SD card fdatasync can take 200-800ms causing spurious leader elections
# and wal sync timeouts that stall the API server briefly.
etcd-arg:
  - "heartbeat-interval=500"
  - "election-timeout=5000"
  - "snapshot-count=5000"
  - "auto-compaction-mode=periodic"
  - "auto-compaction-retention=1"
