# ─── BitComet Configuration ──────────────────────────────────────────────────
BITCOMET_VERSION=latest
CONTAINER_NAME=bitcomet
RESTART_POLICY=unless-stopped

# ─── Port Configuration ─────────────────────────────────────────────────────
BITCOMET_WEBUI_PORT=6080
BITCOMET_BT_PORT=6882

# ─── WebUI Credentials ──────────────────────────────────────────────────────
WEBUI_USERNAME=admin
WEBUI_PASSWORD=admin

# ─── General ─────────────────────────────────────────────────────────────────
TIMEZONE=Asia/Kolkata

# ─── Download Paths ──────────────────────────────────────────────────────────
DOWNLOADS_PATH=/home/pi/pendrive/downloads

# ─── Resource Limits ─────────────────────────────────────────────────────────
MEMORY_LIMIT=512M
MEMORY_RESERVATION=128M
