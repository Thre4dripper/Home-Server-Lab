# ─── Homepage Configuration ──────────────────────────────────────────────────
HOMEPAGE_TAG=latest
CONTAINER_NAME=homepage
RESTART_POLICY=unless-stopped
HOMEPAGE_PORT=3000
TIMEZONE=Asia/Kolkata

# Comma-separated list of allowed hostnames (use * to allow all)
HOMEPAGE_ALLOWED_HOSTS=*

# ─── Server IP (auto-detected by setup.sh, but can be overridden) ───────────
# SERVER_IP=192.168.0.108

# ─── Widget API Keys (used by services.yaml via HOMEPAGE_VAR_*) ─────────────
# Stocks - free API key from https://finnhub.io/
HOMEPAGE_VAR_FINNHUB_KEY=yourfinnhubapikeyhere

# Portainer - generate at Portainer > My Account > API Keys
HOMEPAGE_VAR_PORTAINER_KEY=

# Pi-hole - found at Pi-hole Admin > Settings > API
HOMEPAGE_VAR_PIHOLE_KEY=

# Jellyfin - generate at Jellyfin > Dashboard > API Keys
HOMEPAGE_VAR_JELLYFIN_KEY=

# Plex - get token from https://support.plex.tv/articles/204059436/
HOMEPAGE_VAR_PLEX_KEY=

# qBittorrent credentials
HOMEPAGE_VAR_QBIT_USER=admin
HOMEPAGE_VAR_QBIT_PASS=adminadmin

# Deluge web UI password
HOMEPAGE_VAR_DELUGE_PASS=deluge

# Aria2 RPC secret (from aria2-ui/.env: RPC_SECRET)
HOMEPAGE_VAR_ARIA2_SECRET=your-aria2-rpc-secret-here
