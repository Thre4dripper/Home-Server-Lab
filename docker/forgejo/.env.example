# Forgejo Git Service Configuration
# Copy this file to .env and fill in the values

# ─── Network ────────────────────────────────────────────────────────────────
FORGEJO_DOMAIN=192.168.0.108
FORGEJO_PORT=3000
FORGEJO_HTTP_PORT=3000
FORGEJO_SSH_PORT=2222

# ─── User ───────────────────────────────────────────────────────────────────
USER_UID=1000
USER_GID=1000

# ─── Security ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
FORGEJO_SECRET_KEY=generate_random_key_here
# Generate with: openssl rand -hex 32
FORGEJO_INTERNAL_TOKEN=generate_random_token_here

# ─── Registration ───────────────────────────────────────────────────────────
# Set to true after initial admin account is created
FORGEJO_DISABLE_REGISTRATION=false

# ─── Runner ─────────────────────────────────────────────────────────────────
# Get token: Forgejo → Site Administration → Actions → Runners → "Create new runner"
FORGEJO_RUNNER_REGISTRATION_TOKEN=REPLACE_WITH_TOKEN_FROM_FORGEJO_ADMIN
# Unique name shown in Forgejo runner list
FORGEJO_RUNNER_NAME=laptop-runner
