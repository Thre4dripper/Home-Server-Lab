# Global .gitignore for Home Server Lab

# Environment files with sensitive data
**/.env
**/.env.local
**/.env.production
**/.env.staging

# Kubernetes plain secrets — use sealedsecret.yaml instead (git-safe)
# Keep secret.yaml locally for reference/re-sealing, never commit it
k3s/apps/**/secret.yaml
k3s/databases/**/secret.yaml
k3s/infra/**/secret.yaml

# Ansible Vault — the encrypted vault.yml IS committed; never commit the plaintext version
# (ansible-vault edit will re-encrypt on save automatically)
ansible/group_vars/vault.yml.plaintext

# Database data directories
**/mysql_data/
**/postgres_data/
**/mariadb_data/
**/mongodb_data/

# Application data directories
**/seafile-data/
**/nextcloud_data/
**/plex_data/
**/grafana_data/
**/prometheus_data/
**/elasticsearch_data/
**/logs/
**/data/
**/home-assistant/config/

# SSL certificates and keys (private — keep local)
**/*.key
**/*.crt
**/*.p12
**/certs/
# Private keys and CA certs
**/*.pem
# Exception: Sealed Secrets public cert is safe to commit (public key only)
!k3s/infra/sealed-secrets/public-cert.pem

# Backup files
**/*.sql
**/*.dump
**/backup_*
**/backups/

# Temporary files
**/.tmp/
**/temp/
**/*.tmp
**/*.swp
**/*.swo
**/*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Docker override files (if using local overrides)
**/docker-compose.override.yml

# IDE files
.vscode/
.idea/
**/*.iml

# Log files
**/*.log
**/logs/

# Local configuration overrides
**/local.yml
**/local.json
**/config.local.*

# Runtime data
**/pids/
**/*.pid
**/*.pid.lock

# Coverage reports
**/coverage/
**/.nyc_output/

# Dependency directories
**/node_modules/
**/vendor/

# Python cache
**/__pycache__/
**/*.pyc
**/*.pyo

# Archive files (usually backups)
**/*.tar.gz
**/*.zip
**/*.rar

